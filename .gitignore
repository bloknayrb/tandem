node_modules/
dist/
.tandem/
*.log
.env
.env.local

# Project-local Claude Code MCP config. The repo ships .mcp.json.example as a
# template; the real .mcp.json is developer-local and must NOT be shipped with
# the plugin install (the plugin's own .claude-plugin/plugin.json is
# authoritative for what users see).
.mcp.json

.gemini/
gha-creds-*.json

# Claude Code ephemeral
.agents/
.claude/worktrees/
.claude/settings.local.json
.superpowers/
skills-lock.json
test-results/
.pipeline-state/

# Skill symlinks/junctions managed by Claude Code tooling point into .agents/
# and break git-bash dir walks on Windows (MSYS2 opendir returns ENOSYS for
# NTFS junctions, triggering "Function not implemented" warnings that then
# corrupt lint-staged via tinyexec's merged stderr). Ignore the whole dir,
# then allow-list the real tracked skills. New tracked skills need a new
# allow-list line here.
.claude/skills/*
!.claude/skills/dev-server/
!.claude/skills/e2e/
!.claude/skills/screenshots/
