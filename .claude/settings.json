{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-sensitive.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format-on-edit.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/typecheck-on-edit.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-ymap-keys.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-extract-markdown.sh"
          }
        ]
      }
    ]
  }
}
