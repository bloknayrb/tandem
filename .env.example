# Tandem environment variables (all optional — defaults shown)

# Server ports
TANDEM_PORT=3478          # Hocuspocus WebSocket port
TANDEM_MCP_PORT=3479      # MCP HTTP + REST API port

# Channel shim
TANDEM_URL=http://localhost:3479  # Server URL for channel shim to connect to

# Transport mode (http or stdio)
TANDEM_TRANSPORT=http

# Skip auto-opening sample/welcome.md on first run
# TANDEM_NO_SAMPLE=1

# Claude Code executable name (for tandem setup auto-detection)
# TANDEM_CLAUDE_CMD=claude

# LAN exposure & auth (v0.7.0+)
# TANDEM_BIND_HOST=0.0.0.0
# TANDEM_ALLOW_UNAUTHENTICATED_LAN=1
# TANDEM_LAN_IP=192.168.1.100

# Advanced
# TANDEM_REQUEST_TIMEOUT_MS=30000
# TANDEM_APP_DATA_DIR=/custom/path
# TANDEM_ANNOTATION_STORE=off
