# Tandem environment variables (all optional — defaults shown)

# Server ports
TANDEM_PORT=3478          # Hocuspocus WebSocket port
TANDEM_MCP_PORT=3479      # MCP HTTP + REST API port

# Channel shim
TANDEM_URL=http://localhost:3479  # Server URL for channel shim to connect to

# Transport mode (http or stdio)
TANDEM_TRANSPORT=http

# Skip auto-opening sample/welcome.md on first run
# TANDEM_NO_SAMPLE=1
