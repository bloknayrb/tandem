{
  "name": "tandem",
  "version": "0.14.3",
  "description": "Edit and iterate on documents with any MCP-capable AI. Claude is the default and best-supported client today.",
  "author": {
    "name": "Tandem"
  },
  "repository": "https://github.com/bloknayrb/tandem",
  "license": "MIT",
  "keywords": ["editor", "collaborative", "mcp", "claude"],
  "mcpServers": {
    "tandem": {
      "command": "npx",
      "args": ["-y", "tandem-editor@0.14.3", "mcp-stdio"],
      "env": {
        "TANDEM_URL": "http://127.0.0.1:3479"
      }
    },
    "tandem-channel": {
      "command": "npx",
      "args": ["-y", "tandem-editor@0.14.3", "channel"],
      "env": {
        "TANDEM_URL": "http://127.0.0.1:3479"
      }
    }
  },
  "experimental": {
    "monitors": [
      {
        "name": "tandem-events",
        "command": "node ${CLAUDE_PLUGIN_ROOT}/dist/monitor/index.js",
        "description": "Tandem real-time document events (annotations, chat, selections)"
      }
    ]
  }
}
