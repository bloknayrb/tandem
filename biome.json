{
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "linter": {
    "enabled": false
  },
  "files": {
    "includes": [
      "src/**/*.{ts,tsx,json}",
      "tests/**/*.{ts,tsx}",
      "scripts/**/*.{ts,tsx}",
      "*.{ts,json}",
      "!dist/**",
      "!node_modules/**",
      "!package-lock.json"
    ]
  }
}
