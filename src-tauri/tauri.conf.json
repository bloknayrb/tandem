{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tandem",
  "version": "0.19.0",
  "identifier": "com.tandem.editor",
  "build": {
    "frontendDist": "../dist/client",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tandem",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "fullscreen": false,
        "zoomHotkeysEnabled": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:3478 http://127.0.0.1:3479 ws://127.0.0.1:3478; img-src 'self' data: blob:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/node-sidecar",
      "binaries/tandem-reaper"
    ],
    "macOS": {
      "entitlements": "entitlements.plist"
    },
    "linux": {
      "deb": {
        "depends": ["libxdo3"]
      },
      "rpm": {
        "depends": ["libxdo"]
      }
    },
    "resources": {
      "../dist/server/": "dist/server/",
      "../dist/channel/": "dist/channel/",
      "../dist/client/": "dist/client/",
      "../sample/": "sample/",
      "../skills/": "skills/",
      "../CHANGELOG.md": "CHANGELOG.md",
      "../docs/workflows.md": "docs/workflows.md"
    },
    "windows": {
      "nsis": {
        "installerHooks": "windows/installer-hook.nsi"
      }
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "com.tandem.markdown",
        "description": "Markdown Document",
        "role": "Editor",
        "mimeType": "text/markdown"
      },
      {
        "ext": ["txt"],
        "name": "com.tandem.text",
        "description": "Text Document",
        "role": "Editor",
        "mimeType": "text/plain"
      },
      {
        "ext": ["html"],
        "name": "com.tandem.html",
        "description": "HTML Document",
        "role": "Editor",
        "mimeType": "text/html"
      },
      {
        "ext": ["docx"],
        "name": "com.tandem.docx",
        "description": "Word Document",
        "role": "Editor",
        "mimeType": "application/vnd.openxmlformats-officedocument.wordprocessingml.document"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/bloknayrb/tandem/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzNUEyRjMzOThDQzU2MjcKUldRblZzeVlNeTlhSStVeXdiSzVmMnlEN2p4RzhtOEs3aWYrRjJ3SE84Rnc3SVhyK2FxeWF5MTgK"
    }
  }
}
