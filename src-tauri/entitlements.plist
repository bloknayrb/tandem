<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    macOS hardened-runtime entitlements (#983).

    The bundled `node-sidecar` (Node/V8) is signed with the hardened runtime
    enabled. During V8 initialization, `v8::internal::ThreadIsolation::Initialize`
    calls `pthread_jit_write_protect_np`, which the kernel rejects with SIGTRAP
    unless the JIT entitlement is present — so on Apple Silicon the signed,
    notarized .app crashed the sidecar immediately and never bound :3479.

    `allow-jit` permits the W^X JIT mapping V8 needs; `allow-unsigned-executable-memory`
    is the companion entitlement Node/V8 commonly requires under hardened runtime.
    This is the minimal set verified to make the sidecar survive V8 init.
  -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
</dict>
</plist>
